# =============================================================================
# MySQL Custom Configuration / Cấu Hình Tùy Chỉnh MySQL
# Optimized for development + learning
# Tối ưu cho môi trường phát triển + học tập
# =============================================================================

[mysqld]

# ---------------------------------------------------------------------------
# Character Set / Bộ Ký Tự
# ---------------------------------------------------------------------------
character-set-server        = utf8mb4
collation-server            = utf8mb4_unicode_ci
character-set-client-handshake = OFF

# ---------------------------------------------------------------------------
# Connection Settings / Cài Đặt Kết Nối
# ---------------------------------------------------------------------------
max_connections             = 200
max_connect_errors          = 100000
wait_timeout                = 28800          # 8 hours for dev / 8 giờ cho dev
interactive_timeout         = 28800
connect_timeout             = 10
thread_cache_size           = 16

# ---------------------------------------------------------------------------
# InnoDB Buffer Pool / Bộ Đệm InnoDB
# Set to ~50-70% of available RAM in production
# Đặt 50-70% RAM khả dụng trong production
# ---------------------------------------------------------------------------
innodb_buffer_pool_size     = 512M
innodb_buffer_pool_instances = 2             # 1 per 1GB of buffer pool
innodb_buffer_pool_chunk_size = 128M

# ---------------------------------------------------------------------------
# InnoDB Log / Nhật Ký InnoDB
# ---------------------------------------------------------------------------
innodb_log_file_size        = 128M           # Larger = better write throughput
innodb_log_buffer_size      = 16M
innodb_flush_log_at_trx_commit = 1           # 1 = ACID safe; 2 = faster, less safe
innodb_flush_method         = O_DIRECT       # Bypass OS cache for data files

# ---------------------------------------------------------------------------
# InnoDB Performance / Hiệu Năng InnoDB
# ---------------------------------------------------------------------------
innodb_io_capacity          = 200            # IOPS for flush operations
innodb_io_capacity_max      = 400
innodb_read_io_threads      = 4
innodb_write_io_threads     = 4
innodb_thread_concurrency   = 0              # 0 = auto
innodb_autoinc_lock_mode    = 2              # Interleaved, safe for row-based replication

# ---------------------------------------------------------------------------
# Binary Logging / Nhật Ký Nhị Phân
# ---------------------------------------------------------------------------
log-bin                     = mysql-bin
binlog_format               = ROW
binlog_row_image            = FULL           # Full row images for CDC
binlog_expire_logs_seconds  = 604800         # 7 days
max_binlog_size             = 100M
sync_binlog                 = 1              # Sync to disk on every commit

# ---------------------------------------------------------------------------
# GTID / Global Transaction ID
# ---------------------------------------------------------------------------
gtid_mode                   = ON
enforce_gtid_consistency    = ON

# ---------------------------------------------------------------------------
# Replication / Sao Chép
# ---------------------------------------------------------------------------
server-id                   = 1             # Override per instance in compose
replica_parallel_workers    = 4
replica_parallel_type       = LOGICAL_CLOCK

# ---------------------------------------------------------------------------
# Query Cache (disabled in MySQL 8.0, kept for reference)
# ---------------------------------------------------------------------------
# query_cache_type = 0     # Query cache removed in 8.0

# ---------------------------------------------------------------------------
# Slow Query Log / Nhật Ký Truy Vấn Chậm
# ---------------------------------------------------------------------------
slow_query_log              = ON
slow_query_log_file         = /var/log/mysql/slow.log
long_query_time             = 1              # Log queries slower than 1s
log_queries_not_using_indexes = ON
min_examined_row_limit      = 1000           # Only log if >1000 rows examined

# ---------------------------------------------------------------------------
# General Log (disable in production! / Tắt trong production!)
# ---------------------------------------------------------------------------
general_log                 = OFF
general_log_file            = /var/log/mysql/general.log

# ---------------------------------------------------------------------------
# Error Log / Nhật Ký Lỗi
# ---------------------------------------------------------------------------
log_error                   = /var/log/mysql/error.log
log_error_verbosity         = 2

# ---------------------------------------------------------------------------
# Performance Schema / Schema Hiệu Năng
# ---------------------------------------------------------------------------
performance_schema          = ON
performance_schema_instrument = 'statement/%=ON'

# ---------------------------------------------------------------------------
# Temp Tables / Bảng Tạm
# ---------------------------------------------------------------------------
tmp_table_size              = 64M
max_heap_table_size         = 64M

# ---------------------------------------------------------------------------
# Sort & Join Buffers / Bộ Đệm Sort & Join
# ---------------------------------------------------------------------------
sort_buffer_size            = 4M
join_buffer_size            = 4M
read_buffer_size            = 2M
read_rnd_buffer_size        = 4M

# ---------------------------------------------------------------------------
# Table Cache / Cache Bảng
# ---------------------------------------------------------------------------
table_open_cache            = 4000
table_definition_cache      = 2000
open_files_limit            = 65535

# ---------------------------------------------------------------------------
# Security / Bảo Mật
# ---------------------------------------------------------------------------
local_infile                = OFF            # Disable LOAD DATA LOCAL INFILE
symbolic-links              = 0

[mysql]
default-character-set       = utf8mb4

[client]
default-character-set       = utf8mb4
